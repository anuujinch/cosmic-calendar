# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ClosetIQ

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Database (direct connection — optional, Supabase handles most queries) ───
DATABASE_URL=

# ─── Authentication (NextAuth.js — not used; auth is via Supabase) ────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# OAuth providers (uncomment as needed)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── AI / Wardrobe Intelligence ───────────────────────────────────────────────
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ─── Image Storage (Cloudinary) ───────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
